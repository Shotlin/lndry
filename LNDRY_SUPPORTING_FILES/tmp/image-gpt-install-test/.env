# Copy to .env and fill in. Do NOT commit .env.
# Generate the two secrets with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Both must be 16-256 chars.

KIRO_SECRET=
AGENT_SECRET=

PORT=3001
RELAY_URL=ws://localhost:3001

AGENT_PROFILE_DIR=

QUEUE_MAX_DEPTH=1000

RELAY_TLS_ENABLED=false
RELAY_TLS_CERT=
RELAY_TLS_KEY=

KIRO_GPT_MCP_SECRET=
KIRO_GPT_MCP_RELAY_URL=ws://localhost:3001
# Optional: absolute path to a project workspace where generated assets
# are written. When unset, the MCP server falls back to the local-device
# default below so it works out of the box.
KIRO_GPT_MCP_WORKSPACE=
# Optional: override the local-device default download folder. When
# KIRO_GPT_MCP_WORKSPACE (and any per-call workspace_root) is unset,
# generated files are saved here. Defaults to
# "<home>/Downloads/kiro-gpt-bridge" when left empty.
KIRO_GPT_MCP_DOWNLOAD_DIR=
# Optional: project-wide opt-in for the LLM-rewrite prompt enhancer.
# When set to one of "1", "true", "yes", "on" (case-insensitive), every
# image-tool call runs the user's brief through ChatGPT to expand it
# into a high-quality DALL-E prompt before image generation. Adds one
# extra chat round-trip (~5-15 s) per call. Leave empty to default off;
# callers can still opt in per-call by passing `enhance_prompt: true`.
KIRO_GPT_MCP_PROMPT_REWRITE=
